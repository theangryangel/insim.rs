{
  "extends": ["config:recommended"],
  "cargo": {
    "rangeStrategy": "replace"
  },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchDepTypes": ["workspace.dependencies"],
      "enabled": true,
      "separateMajorMinor": true,
      "separateMultipleMajor": true
    },
    {
      "description": "Only major updates for specific crates",
      "matchManagers": ["cargo"],
      "matchDepTypes": ["workspace.dependencies"],
      "matchPackageNames": ["syn", "quote", "proc-macro2"],
      "matchUpdateTypes": ["minor", "patch"],
      "enabled": false
    },
    {
      "description": "Only minor updates for specific crates",
      "matchManagers": ["cargo"],
      "matchDepTypes": ["workspace.dependencies"],
      "matchPackageNames": ["num-traits"],
      "matchUpdateTypes": ["patch"],
      "enabled": false
    },
    {
      "description": "Group sha2 and digest",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["sha2", "digest"],
      "groupName": "cargo:digest"
    }
  ]
}
